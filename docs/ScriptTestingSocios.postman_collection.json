        {
          "name": "/socios200",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "if (pm.response.code === 200) {\r",
                  "    const socios = pm.response.json();\r",
                  "\r",
                  "    pm.test(\"Response is an array\", function () {\r",
                  "        pm.expect(socios).to.be.an(\"array\");\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Array is not empty\", function () {\r",
                  "        pm.expect(socios.length).to.be.greaterThan(0);\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"Each socio has the required fields\", function () {\r",
                  "        socios.forEach(function (socio) {\r",
                  "            pm.expect(socio).to.include.all.keys(\r",
                  "                \"id\", \"dni\", \"name\", \"surname\", \"email\",\r",
                  "                \"phoneNumber\", \"active\", \"familyModel\", \"entryDate\"\r",
                  "            );\r",
                  "        });\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"'id' is a number in each socio\", function () {\r",
                  "        socios.forEach(function (socio) {\r",
                  "            pm.expect(socio.id).to.be.a(\"number\");\r",
                  "        });\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"'active' is a boolean in each socio\", function () {\r",
                  "        socios.forEach(function (socio) {\r",
                  "            pm.expect(socio.active).to.be.a(\"boolean\");\r",
                  "        });\r",
                  "    });\r",
                  "\r",
                  "    pm.test(\"'entryDate' matches date format (YYYY-MM-DD) in each socio\", function () {\r",
                  "        const dateRegex = /^\\d{4}-\\d{2}-\\d{2}$/;\r",
                  "        socios.forEach(function (socio) {\r",
                  "            pm.expect(socio.entryDate).to.match(dateRegex);\r",
                  "        });\r",
                  "    });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
