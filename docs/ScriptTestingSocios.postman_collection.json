      "item": [
        {
          "name": "/socios201",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "//se comprueba el estado de la respuesta",
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.expect(pm.response.code).to.equal(201);",
                  "});",
                  "",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const socio = pm.response.json();",
                  "    ",
                  "    pm.test(\"Content-Type is application/json\", function () {",
                  "        pm.response.to.have.header(\"Content-Type\");",
                  "        pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
                  "    });",
                  "",
                  "    //comprobamos estructura de la respuesta",
                  "    pm.test(\"Created socio has required fields\", function () {",
                  "        pm.expect(socio).to.include.all.keys(\"id\", \"dni\", \"name\", \"phoneNumber\", \"active\", \"familyModel\", \"entryDate\");",
                  "    });",
                  "",
                  "    //comprobamos los valores de las variables de la respuesta",
                  "    pm.test(\"'id' is a number\", function () {",
                  "        pm.expect(socio.id).to.be.a(\"number\");",
                  "    });",
                  "",
                  "    pm.test(\"Returned 'dni' matches sent value\", function () {",
                  "        pm.expect(socio.dni).to.eql(pm.variables.get(\"dni\"));",
                  "    });",
                  "",
                  "    pm.test(\"Returned 'name' matches sent value\", function () {",
                  "        pm.expect(socio.name).to.eql(pm.variables.get(\"name\"));",
                  "    });",
                  "",
                  "    pm.test(\"Returned 'phoneNumber' matches sent value\", function () {",
                  "        pm.expect(socio.phoneNumber).to.eql(pm.variables.get(\"phoneNumber\"));",
                  "    });",
                  "",
                  "    pm.test(\"Returned 'familyModel' matches sent value\", function () {",
                  "        pm.expect(socio.familyModel).to.eql(\"Nuclear\");",
                  "    });",
                  "",
                  "    const socioId = String(socio.id);",
                  "",
                  "    pm.collectionVariables.set(\"socioId\", socioId);",
                  "    // opcional: también en environment si lo usas en ese scope",
                  "    pm.environment.set(\"socioId\", socioId);",
                  "",
                  "    console.log(\"socioId guardado:\", socioId);",
                  "}",
                  "",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
