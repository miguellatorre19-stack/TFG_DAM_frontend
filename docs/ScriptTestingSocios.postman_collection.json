            {
              "listen": "test",
              "script": {
                "exec": [
                  "// --- 200 / 201 / 204: Socio updated successfully ---",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.expect(pm.response.code).to.eq(200)",
                  "});",
                  "",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    pm.test(\"Content-Type is application/json\", function () {",
                  "        pm.response.to.have.header(\"Content-Type\");",
                  "        pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
                  "    });",
                  "",
                  "    const socio = pm.response.json();",
                  "",
                  "    pm.test(\"Updated socio has required fields\", function () {",
                  "        pm.expect(socio).to.include.all.keys(\"id\", \"dni\", \"name\", \"surname\", \"email\", \"phoneNumber\", \"active\", \"familyModel\", \"entryDate\");",
                  "    });",
                  "",
                  "    pm.test(\"Returned 'id' matches updated socioId\", function () {",
                  "        const socioId = pm.collectionVariables.get(\"socioId\");",
                  "        pm.expect(String(socio.id)).to.eql(String(socioId));",
                  "    });",
                  "",
                  "    pm.test(\"Returned 'dni' matches sent value\", function () {",
                  "        pm.expect(socio.dni).to.eql(pm.variables.get(\"dni\"));",
                  "    });",
                  "",
                  "    pm.test(\"Returned 'name' matches sent value\", function () {",
                  "        pm.expect(socio.name).to.eql(pm.variables.get(\"name\"));",
                  "    });",
                  "",
                  "    pm.test(\"Returned 'surname' matches sent value\", function () {",
                  "        pm.expect(socio.surname).to.eql(pm.variables.get(\"surname\"));",
                  "    });",
                  "",
                  "    pm.test(\"Returned 'active' matches sent value\", function () {",
                  "        const activeVar = pm.variables.get(\"active\");",
                  "        const expectedActive = (activeVar === true || activeVar === \"true\");",
                  "        pm.expect(socio.active).to.eql(expectedActive);",
                  "    });",
                  "",
                  "    pm.test(\"Returned 'familyModel' matches sent value\", function () {",
                  "        pm.expect(socio.familyModel).to.eql(\"Nuclear\");",
                  "    });",
                  "}",
                  "",
                  "if (pm.response.code === 204) {",
                  "    pm.test(\"No content body on 204\", function () {",
                  "        pm.expect(pm.response.text()).to.be.empty;",
                  "    });",
                  "}",
                  "",
                  "// --- 400: Validation error ---",
                  "if (pm.response.code === 400) {",
                  "    const err = pm.response.json();",
                  "",
                  "    pm.test(\"Error body has required fields\", function () {",
                  "        pm.expect(err).to.include.all.keys(\"code\", \"message\");",
                  "    });",
                  "",
                  "    pm.test(\"Error code matches HTTP status\", function () {",
                  "        pm.expect(err.code).to.eql(400);",
                  "    });",
                  "}",
                  "",
                  "// --- 404: Socio not found ---",
                  "if (pm.response.code === 404) {",
                  "    const err = pm.response.json();",
                  "",
                  "    pm.test(\"Error body has required fields\", function () {",
                  "        pm.expect(err).to.include.all.keys(\"code\", \"message\", \"title\");",
                  "    });",
                  "",
                  "    pm.test(\"Error code matches HTTP status\", function () {",
                  "        pm.expect(err.code).to.eql(404);",
                  "    });",
                  "}"
