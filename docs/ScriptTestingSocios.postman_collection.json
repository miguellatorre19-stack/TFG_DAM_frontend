              "listen": "test",
              "script": {
                "exec": [
                  "// --- 400: Validation error ---",
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([400]);",
                  "});",
                  "",
                  "pm.collectionVariables.unset(\"dni\")",
                  "// --- 400 / 422: Validation error ---",
                  "if (pm.response.code === 400 || pm.response.code === 422) {",
                  "    const err = pm.response.json();",
                  "",
                  "    pm.test(\"Error body has required fields\", function () {",
                  "        pm.expect(err).to.include.all.keys(\"code\", \"message\");",
                  "        pm.expect(err.message).to.eql(\"Validation failed for one or more fields\")",
                  "        pm.expect(err.title).to.eql(\"Bad Request\")",
                  "",
                  "    });",
                  "",
                  "    pm.test(\"Error code matches HTTP status\", function () {",
                  "        pm.expect(err.code).to.eql(pm.response.code);",
                  "    });",
                  "",
                  "}"
